# Banco de dados PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/guiadispatcher"

# JWT - gere uma string aleatória longa
JWT_SECRET="sua-chave-secreta-muito-longa-aqui-min-32-chars"
JWT_EXPIRES_IN="7d"

# Servidor
PORT=3000
NODE_ENV=development

# Evolution API (WhatsApp)
EVOLUTION_API_URL="http://localhost:8080"
EVOLUTION_API_KEY="sua-api-key-da-evolution"

# Redis (filas)
REDIS_URL="redis://localhost:6379"

# Claude API (leitura de PDF)
ANTHROPIC_API_KEY="sk-ant-..."

# Storage (S3 ou compatível - ex: Cloudflare R2)
S3_ENDPOINT="https://..."
S3_ACCESS_KEY="..."
S3_SECRET_KEY="..."
S3_BUCKET="guiadispatcher"
