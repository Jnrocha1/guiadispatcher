generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  passwordHash String
  plan        Plan     @default(STARTER)
  active      Boolean  @default(true)
  trialEndsAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clients     Client[]
  folders     Folder[]
  sendLogs    SendLog[]
  whatsappConnections WhatsappConnection[]

  @@map("tenants")
}

model Client {
  id        String  @id @default(cuid())
  tenantId  String
  name      String
  phone     String
  document  String?  // CPF ou CNPJ
  active    Boolean @default(true)
  createdAt DateTime @default(now())

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sendLogs  SendLog[]

  @@unique([tenantId, phone])
  @@map("clients")
}

model Folder {
  id           String     @id @default(cuid())
  tenantId     String
  name         String
  type         FolderType @default(LOCAL)
  path         String     // caminho local ou ID do Google Drive
  clientId     String?    // pasta vinculada a 1 cliente específico (opcional)
  active       Boolean    @default(true)
  createdAt    DateTime   @default(now())

  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("folders")
}

model WhatsappConnection {
  id        String   @id @default(cuid())
  tenantId  String   @unique
  instance  String   // nome da instância na Evolution API
  status    WaStatus @default(DISCONNECTED)
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("whatsapp_connections")
}

model SendLog {
  id          String     @id @default(cuid())
  tenantId    String
  clientId    String?
  clientPhone String
  fileName    String
  fileUrl     String?
  docType     String?    // DAS, DARF, Boleto, etc
  docValue    String?
  docDueDate  String?
  message     String
  status      SendStatus @default(PENDING)
  sentAt      DateTime?
  readAt      DateTime?
  errorMsg    String?
  retries     Int        @default(0)
  createdAt   DateTime   @default(now())

  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client      Client?    @relation(fields: [clientId], references: [id])

  @@map("send_logs")
}

enum Plan {
  STARTER
  PRO
  ENTERPRISE
}

enum FolderType {
  LOCAL
  GOOGLE_DRIVE
}

enum WaStatus {
  DISCONNECTED
  CONNECTING
  CONNECTED
}

enum SendStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}
